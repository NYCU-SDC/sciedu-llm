# OpenAI Compatible Server
OPENAI_API_KEY=
OPENAI_BASE_URL=

# LangFuse
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# Optional Configuration
RAG_EMBEDDING_BATCH_SIZE=64
RAG_MAX_CONCURRENCY=128

# Langfuse batching: score events are queued and POSTed in batches of FLUSH_AT
# events (or every FLUSH_INTERVAL seconds, whichever comes first). Defaults are
# tuned to reduce IO during judge runs. The same vars also tune the OTEL span
# batch processor, so larger values batch trace exports too.
LANGFUSE_FLUSH_AT=200
LANGFUSE_FLUSH_INTERVAL=5
