# OpenAI Compatible Server
OPENAI_API_KEY=
OPENAI_BASE_URL=

# LangFuse
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=
LANGFUSE_TRACING_ENVIRONMENT=local

# Langfuse batching
LANGFUSE_FLUSH_AT=200
LANGFUSE_FLUSH_INTERVAL=5

# RAG pipeline config
# Comma-separated Langfuse corpus dataset names to index for RAG-enabled chat
# (the /chat `enable_rag` flag). Leave empty to disable RAG in the app.
RAG_CORPUS_DATASETS=
RAG_EMBEDDING_MODEL=bge-m3
RAG_RERANK_MODEL=BGE-Reranker-V2-M3
RAG_EMBEDDING_BATCH_SIZE=64
RAG_MAX_CONCURRENCY=64
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
RAG_GENERATOR_PROMPT_NAME=rag-generator-instruction

# Judge config
JUDGE_PROMPT_FOLDER=judge
JUDGE_EXTRACT_PROMPT_NAME=extract-score-from-judgement
JUDGE_MAX_EXTRACT_RETRIES=10
JUDGE_FAILED_SCORE=-1.0

# Eval UI config
EVAL_UI_PORT=7860
EVAL_UI_CORPUS_DATASET_FOLDER=corpus
EVAL_UI_QUESTIONS_DATASET_FOLDER=questions
